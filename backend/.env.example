# ============================================================
# Backend Application Environment
# ------------------------------------------------------------
# These vars are read by the FastAPI app, Celery worker, and
# Celery beat via docker-compose `env_file: backend/.env`.
# They configure application code (Pydantic Settings, OpenAI
# client, MinIO client, Langfuse SDK, JWT, encryption, etc.).
#
# Compose-level vars (HOST_*_PORT, DB_USER/DB_PASSWORD for the
# db service block, MINIO root creds for the minio service
# block, LANGFUSE_SECRET_KEY for the langfuse service block)
# live in the root .env file. Some values are duplicated here
# so application containers see them via env_file.
#
# Copy this file to backend/.env and fill in values.
# NEVER commit backend/.env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/knowledge_agent

# --- Cache / Message Broker ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (MinIO) ---
# MINIO_ENDPOINT — in-network address backend uses to talk to MinIO.
# MINIO_PUBLIC_ENDPOINT — host-exposed address for browser presigned URLs
# (compose overrides MINIO_PUBLIC_ENDPOINT at runtime to track HOST_MINIO_API_PORT).
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET=knowledge-agent
MINIO_SECURE=False
# Duplicated from root .env — backend's MinIO client reads these directly.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<change-me>

# --- JWT Authentication ---
JWT_SECRET_KEY=<change-me-256bit>
JWT_REFRESH_SECRET_KEY=<change-me-256bit>
# Cookies are issued without the Secure flag for http://localhost dev.
# In production this MUST be true (HTTPS-only).
COOKIE_SECURE=false

# --- LangFuse Observability ---
# LANGFUSE_SECRET_KEY duplicates the value in root .env (compose uses
# it as NEXTAUTH_SECRET for the Langfuse v2 web UI).
LANGFUSE_SECRET_KEY=<langfuse-sk>
LANGFUSE_PUBLIC_KEY=<langfuse-pk>
LANGFUSE_HOST=http://langfuse:3000

# --- Bootstrap Admin Account ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=<change-me>

# --- Encryption (Fernet key for connection configs) ---
ENCRYPTION_KEY=<fernet-key-base64>

# --- Rate limiting (per-IP, sliding window, seconds) ---
RATE_LIMIT_AUTH_LOGIN_LIMIT=20
RATE_LIMIT_AUTH_LOGIN_WINDOW=60
RATE_LIMIT_AUTH_REFRESH_LIMIT=60
RATE_LIMIT_AUTH_REFRESH_WINDOW=60
RATE_LIMIT_API_LIMIT=500
RATE_LIMIT_API_WINDOW=60

# --- Account Lockout (per-email-hash, layered on top of per-IP rate limit) ---
# LOCKOUT_ENABLED=true
# LOCKOUT_REQUIRE_REDIS=true   # fail-closed (HTTP 503) if Redis is down
#                              # default true in production, false in dev
# LOCKOUT_MAX_FAILS=10
# LOCKOUT_WINDOW_SECS=900       # 15 min sliding window
# LOCKOUT_DURATION_SECS=1800    # 30 min lockout after threshold

# --- Sync Cancellation (U16) ---
# When the running sync_source / study_source Celery task hits a
# cooperative-cancel checkpoint and Redis is unreachable, this flag
# decides what to do:
#   true  — re-raise the Redis error (the task fails via its standard
#           failure path; admin can retry). Default in production: a
#           transient Redis blip MUST NOT silently treat a live sync as
#           cancelled, and MUST NOT silently treat a cancel request as
#           "not received".
#   false — log a warning and treat the read as "not cancelled" so the
#           in-flight task continues. Auto-applied in dev so contributors
#           without Redis can run the worker.
# SYNC_CANCELLATION_REQUIRE_REDIS=true

# --- LangGraph Pipeline ---
# Toggle the v2 pipeline (LLM clarify + query_analyzer + source_router +
# text_to_query + optional reflector). Set to false to roll back to the
# legacy single-shot pipeline (~30s rollback via backend restart).
# PIPELINE_V2_ENABLED=true
# Reflector self-critic — costly per Constitution; OFF by default.
# PIPELINE_REFLECTOR_ENABLED=false
# PIPELINE_REFLECTOR_MAX_RETRIES=1

# --- LLM Provider ---
OPENAI_API_KEY=<openai-api-key>
