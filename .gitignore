# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
# Allow frontend/src/lib — the lib/ rule above is for Python virtualenvs
!frontend/src/lib/
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
vendor/
env/
ENV/

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# =============================================================
# Node / Next.js
# =============================================================
node_modules/
.npm/
.yarn/
.next/
out/
frontend/dist/
frontend/build/
# TS incremental build cache (per-machine, churns on every type-check)
*.tsbuildinfo

# =============================================================
# Claude Code local state (not project source)
# =============================================================
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# =============================================================
# Environment Variables (CRITICAL — never commit secrets)
# =============================================================
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# =============================================================
# Docker
# =============================================================
.docker/

# =============================================================
# Editors & OS
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*.orig
.idea/
.vscode/**
!.vscode/extensions.json
!.vscode/settings.json

# =============================================================
# Logs & Temp
# =============================================================
*.log
logs/
tmp/
temp/

# =============================================================
# Alembic
# =============================================================
backend/alembic/versions/__pycache__/

# =============================================================
# Testing
# =============================================================
playwright-report/
test-results/
frontend/e2e/.auth/
# Playwright HTML report output (was committed by accident — held a stray
# screenshot from an unrelated app). Keep it out of the tree.
frontend/e2e/report/
# pytest run logs — leak local Windows user paths in stack traces.
backend/pytest_out*.txt
backend/pytest_output*.txt
# stray test-output dumps at the repo root (leak local paths).
test_*_out.txt

# Local Docker Compose dev override (hot-reload bind mounts + UID remap).
# docker compose auto-merges this file, so it must NOT be committed — a
# public `docker compose up` should run clean built images. Copy
# docker-compose.override.yml.example to opt into hot-reload locally.
docker-compose.override.yml

# =============================================================
# Conversation/reference scratch (not project source)
# =============================================================
# ReferenceImage holds screenshots shared during dev conversations only.
docs/ReferenceImage/

# =============================================================
# SpecKit (internal AI agent scaffolding - not part of project source)
# =============================================================
memory/
scripts/
specs/_defaults/
templates/
.specify/