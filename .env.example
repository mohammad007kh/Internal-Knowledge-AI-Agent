# ============================================================
# Root Environment Variables — Compose-only scope
# ------------------------------------------------------------
# These vars are consumed by docker-compose.yml itself, NOT by
# application containers. Two consumption paths:
#   1) ${VAR} substitution into compose service blocks
#   2) HOST_*_PORT mapping for "ports:" entries
#
# Application config lives in backend/.env (see
# backend/.env.example). Do NOT add backend secrets here.
#
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# ============================================================

# --- Database (compose substitution into db service block) ---
DB_USER=postgres
DB_PASSWORD=<change-me>

# --- Object Storage (compose substitution into minio service block) ---
# MinIO server reads these as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# Backend's MinIO client also needs these — duplicate the same values
# in backend/.env so the application picks them up via env_file.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<change-me>

# --- LangFuse (compose substitution into langfuse service block) ---
# Used as NEXTAUTH_SECRET for the Langfuse v2 web UI.
# Backend reads its own copy from backend/.env (duplicate the value).
LANGFUSE_SECRET_KEY=<langfuse-sk>

# --- Celery (compose substitution into worker service block) ---
CELERY_WORKER_CONCURRENCY=4

# --- Host Port Mapping (override to avoid clashes with other projects) ---
# Leave commented to keep defaults (3000/8000/5432/6379/9000/9001/3001).
# Set any subset; only the ones you uncomment will shift.
# HOST_FRONTEND_PORT=3100
# Note: changing HOST_BACKEND_PORT requires a frontend rebuild:
#   docker compose build frontend
# HOST_BACKEND_PORT=8001
# HOST_DB_PORT=5435
# HOST_REDIS_PORT=6380
# (compose auto-derives MINIO_PUBLIC_ENDPOINT from this port)
# Note: changing HOST_MINIO_API_PORT requires a frontend rebuild so the
# upload-trust allowlist (NEXT_PUBLIC_MINIO_PUBLIC_URL) is re-inlined:
#   docker compose build frontend
# HOST_MINIO_API_PORT=9100
# HOST_MINIO_CONSOLE_PORT=9101
# HOST_LANGFUSE_PORT=3101
