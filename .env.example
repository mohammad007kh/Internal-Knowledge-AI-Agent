# ============================================================
# Root Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/knowledge_agent

# --- Cache / Message Broker ---
REDIS_URL=redis://redis:6379/0

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-agent
# Compose overrides this from HOST_MINIO_API_PORT — value here is for
# bare-metal/non-compose runs only. Used to build presigned URLs that the
# browser can reach.
MINIO_PUBLIC_ENDPOINT=localhost:9000

# --- JWT Authentication ---
JWT_SECRET_KEY=<change-me-256bit>
JWT_REFRESH_SECRET_KEY=<change-me-256bit>

# --- LangFuse Observability ---
LANGFUSE_SECRET_KEY=<langfuse-sk>
LANGFUSE_PUBLIC_KEY=<langfuse-pk>
LANGFUSE_HOST=http://langfuse:3000

# --- Bootstrap Admin Account ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=<change-me>

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Encryption (Fernet key for connection configs) ---
ENCRYPTION_KEY=<fernet-key-base64>

# --- Celery ---
CELERY_WORKER_CONCURRENCY=4

# --- Host Port Mapping (override to avoid clashes with other projects) ---
# Leave commented to keep defaults (3000/8000/5432/6379/9000/9001/3001).
# Set any subset; only the ones you uncomment will shift.
# HOST_FRONTEND_PORT=3100
# Note: changing HOST_BACKEND_PORT requires a frontend rebuild:
#   docker compose build frontend
# HOST_BACKEND_PORT=8001
# HOST_DB_PORT=5435
# HOST_REDIS_PORT=6380
# (compose auto-derives MINIO_PUBLIC_ENDPOINT from this port)
# HOST_MINIO_API_PORT=9100
# HOST_MINIO_CONSOLE_PORT=9101
# HOST_LANGFUSE_PORT=3101
