# Frontend environment variables
# Copy to .env.local and fill in values

NEXT_PUBLIC_API_URL=http://localhost:8000

# Public origin where MinIO serves presigned uploads to the browser.
# Must match the backend's MINIO_PUBLIC_ENDPOINT (host-port-aware).
# Used by the upload-trust allowlist in src/hooks/use-upload-url.ts.
# Inlined at Next.js build time — rebuild the frontend after changing.
NEXT_PUBLIC_MINIO_PUBLIC_URL=http://localhost:9000
